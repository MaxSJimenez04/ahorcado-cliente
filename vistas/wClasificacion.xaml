<Page x:Class="ClienteAhorcado.vistas.wClasificacion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wClasificacion">

    <Grid Background="Transparent">
        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.65*"/>
                <RowDefinition Height="0.15*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" 
                        Name="btnRegresar" Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
                    <Path Data="{StaticResource IconoRegresar}" Fill="#F4F3F2" Width="30" Height="30" Stretch="Fill"/>
                </Button>

                <TextBlock Grid.Column="1" Text="Clasificación" VerticalAlignment="Center" 
                           HorizontalAlignment="Left" Margin="50,0,0,0" Style="{StaticResource titulos}"/>
            </Grid>

            <Border Grid.Row="1" Background="#D9D9D9" CornerRadius="15" Padding="30" Margin="0,0,0,15">
                <ListBox Name="lbClasificacion" Background="Transparent" BorderThickness="0" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Margin" Value="0,0,0,12"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="8">
                                <Grid Height="60">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="2"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{Binding ColorMedalla}" CornerRadius="8,0,0,8">
                                        <TextBlock Text="{Binding PosicionStr}" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource texto}" FontWeight="Bold" Foreground="#1E1E1E"/>
                                    </Border>

                                    <Border Grid.Column="1" Background="#D5CFCF"/>

                                    <TextBlock Grid.Column="2" Text="{Binding Usuario}" VerticalAlignment="Center" Margin="20,0,0,0" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PuntosStr}" VerticalAlignment="Center" Margin="0,0,60,0" Style="{StaticResource texto}" Foreground="#807D7D"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>

                </ListBox>
            </Border>

            <Grid Grid.Row="2" VerticalAlignment="Center">
                <Border Background="#FFFFFF" BorderBrush="#807D7D" BorderThickness="2" CornerRadius="8" Padding="0">
                    <Grid Height="60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="2"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="6,0,0,6">
                            <TextBlock Name="txtMiPosicion" Text="-°" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource texto}" FontWeight="Bold" Foreground="#1E1E1E"/>
                        </Border>

                        <Border Grid.Column="1" Background="#D5CFCF"/>

                        <TextBlock Grid.Column="2" Name="txtMiUsuario" Text="Cargando..." VerticalAlignment="Center" Margin="20,0,0,0" Style="{StaticResource texto}" FontWeight="DemiBold" Foreground="#28A745"/>
                        <TextBlock Grid.Column="3" Name="txtMisPuntos" Text="0 pts" VerticalAlignment="Center" Margin="0,0,60,0" Style="{StaticResource texto}" FontWeight="Bold"/>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</Page>
