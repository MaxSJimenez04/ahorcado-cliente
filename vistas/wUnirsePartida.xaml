<Page x:Class="ClienteAhorcado.vistas.wUnirsePartida"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wUnirsePartida">

    <Grid Background="Transparent">
        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.60*"/>
                <RowDefinition Height="0.20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" 
                        Name="btnRegresar" Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
                    <Path Data="{StaticResource IconoRegresar}" Fill="#F4F3F2" Width="30" Height="30" Stretch="Fill"/>
                </Button>

                <TextBlock Grid.Column="1" Text="Unirse a Partida" VerticalAlignment="Center" 
                           HorizontalAlignment="Left" Margin="50,0,0,0" Style="{StaticResource titulos}"/>

                <Button Grid.Column="2" Name="btnActualizar" Click="btnActualizar_Click" 
                        Width="Auto" Height="60" Padding="20,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <Rectangle Width="25" Height="25" Fill="#F4F3F2" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="../resources/img/actualizar.png" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>

                        <TextBlock Text="ACTUALIZAR" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="#D9D9D9" CornerRadius="15" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.30*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.30*"/>
                            <ColumnDefinition Width="0.15*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Nombre Partida" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="1" Text="Nombre Usuario" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="2" Text="Correo Usuario" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="3" Text="Fecha Creación" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                    </Grid>

                    <ListBox Name="lbPartidas" Grid.Row="1" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,15"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBoxItem>
                            <Border Background="#ABABAB" CornerRadius="8" Padding="10,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.30*"/>
                                        <ColumnDefinition Width="0.25*"/>
                                        <ColumnDefinition Width="0.30*"/>
                                        <ColumnDefinition Width="0.15*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Partida Épica" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="1" Text="JugadorPro" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="2" Text="jugador@correo.com" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="3" Text="05/06/2026" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                </Grid>
                            </Border>
                        </ListBoxItem>

                        <ListBoxItem>
                            <Border Background="#ABABAB" CornerRadius="8" Padding="10,15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.30*"/>
                                        <ColumnDefinition Width="0.25*"/>
                                        <ColumnDefinition Width="0.30*"/>
                                        <ColumnDefinition Width="0.15*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Los Novatos" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="1" Text="Admin123" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="2" Text="admin@juego.com" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    <TextBlock Grid.Column="3" Text="04/06/2026" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                </Grid>
                            </Border>
                        </ListBoxItem>
                    </ListBox>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Name="btnUnirsePartida" Content="UNIRSE" Click="btnUnirsePartida_Click"/>
            </StackPanel>

        </Grid>
    </Grid>
</Page>
