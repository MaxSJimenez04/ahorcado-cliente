<Page x:Class="ClienteAhorcado.vistas.wUnirsePartida"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wUnirsePartida">

    <Grid Background="Transparent">
        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.60*"/>
                <RowDefinition Height="0.20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" 
                        Name="btnRegresar" Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
                    <Path Data="{StaticResource IconoRegresar}" Fill="#F4F3F2" Width="30" Height="30" Stretch="Fill"/>
                </Button>

                <TextBlock Grid.Column="1" Text="{x:Static res:Resources.titUnirsePartida}" VerticalAlignment="Center" 
                        HorizontalAlignment="Left" Margin="50,0,0,0" Style="{StaticResource titulos}"/>

                <Button Grid.Column="2" Name="btnActualizar" Click="btnActualizar_Click" 
                        Width="Auto" Height="60" Padding="20,0" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Rectangle Width="25" Height="25" Fill="#F4F3F2" Margin="0,0,10,0" VerticalAlignment="Center">
                            <Rectangle.OpacityMask>
                                <ImageBrush ImageSource="../resources/img/actualizar.png" Stretch="Uniform"/>
                            </Rectangle.OpacityMask>
                        </Rectangle>
                        <TextBlock Text="{x:Static res:Resources.textActualizar}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Grid.Row="1" Background="#D9D9D9" CornerRadius="15" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="10,0,10,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.30*"/>
                            <ColumnDefinition Width="0.25*"/>
                            <ColumnDefinition Width="0.30*"/>
                            <ColumnDefinition Width="0.15*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static res:Resources.columNombrePartida}" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="1" Text="{x:Static res:Resources.columNombreUsuario}" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="2" Text="{x:Static res:Resources.columCorreo}" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                        <TextBlock Grid.Column="3" Text="{x:Static res:Resources.columFecha}" Style="{StaticResource texto}" FontWeight="DemiBold"/>
                    </Grid>

                    <ListBox Name="lbPartidas" Grid.Row="1" Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,15"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#ABABAB" CornerRadius="8" Padding="10,15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.30*"/>
                                            <ColumnDefinition Width="0.25*"/>
                                            <ColumnDefinition Width="0.30*"/>
                                            <ColumnDefinition Width="0.15*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding nombrePartida}" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                        <TextBlock Grid.Column="1" Text="{Binding usuarioJugadorA}" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                        <TextBlock Grid.Column="2" Text="{Binding correoJugadorA}" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                        <TextBlock Grid.Column="3" Text="{Binding fechaCreacion}" Style="{StaticResource texto}" Foreground="#1E1E1E"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Name="btnUnirsePartida" Content="{x:Static res:Resources.btnUnirse}" Click="btnUnirsePartida_Click"/>
            </StackPanel>

        </Grid>
    </Grid>
</Page>