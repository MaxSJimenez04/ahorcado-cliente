<Page x:Class="ClienteAhorcado.vistas.wPerfil"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wPerfil">

    <Grid Background="Transparent">
        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.60*"/>
                <RowDefinition Height="0.20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" 
                        Name="btnRegresar" Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
                    <Path Data="{StaticResource IconoRegresar}" Fill="#F4F3F2" Width="30" Height="30" Stretch="Fill"/>
                </Button>

                <TextBlock Grid.Column="1" Text="{x:Static res:Resources.btnEditarPerfil}" VerticalAlignment="Center" 
                           HorizontalAlignment="Left" Margin="50,0,0,0" Style="{StaticResource titulos}"/>
            </Grid>

            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="0.5*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="60,0,45,0">
                    <TextBlock Text="{x:Static res:Resources.textNombres}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtNombre" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textPrimerApellido}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtPrimerApellido" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textSegundoApellido}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtSegundoApellido" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textFechaNacimiento}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtFechaNacimiento" Height="60" Margin="0,0,0,20" IsEnabled="False"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="45,0,60,0">
                    <TextBlock Text="{x:Static res:Resources.textNombreUsuario}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtNombreUsuario" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textCorreo}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtCorreo" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textTelefono}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <TextBox Name="txtTelefono" Height="60" Margin="0,0,0,20" IsEnabled="False"/>

                    <TextBlock Text="{x:Static res:Resources.textContraseña}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <PasswordBox Name="pbContraseniaOculta" Height="60" Width="Auto" Margin="0,0,0,20" IsEnabled="False" Password="••••••••"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" VerticalAlignment="Center" Margin="60,0">
                <Button Name="btnEstadisticas" HorizontalAlignment="Left" Height="60" Padding="20,0" Click="btnEstadisticas_Click">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="{StaticResource IconoClasificacion}" Fill="#F4F3F2" Width="24" Height="24" Stretch="Fill" Margin="0,0,10,0"/>
                        <TextBlock Text="{x:Static res:Resources.btnMisEstadísticas}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Name="btnEditarPerfil" HorizontalAlignment="Right" Content="{x:Static res:Resources.btnEditarPerfil}" Click="btnEditarPerfil_Click"/>
            </Grid>

        </Grid>
    </Grid>
</Page>
