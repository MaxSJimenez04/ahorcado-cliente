<Page x:Class="ClienteAhorcado.vistas.wEsperaJugador"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wEsperaJugador">

    <Grid Background="Transparent">
        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.60*"/>
                <RowDefinition Height="0.20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Button HorizontalAlignment="Left" VerticalAlignment="Center" 
                        Name="btnCancelarPartida" Width="60" Height="60" 
                        Background="#FFFFFF" BorderBrush="#807D7D" BorderThickness="2" Cursor="Hand" Click="btnCancelarPartida_Click"
                        ToolTip="{x:Static res:Resources.titCancelarPartida}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Borde" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Borde" Property="Background" Value="#E0E0E0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Image Source="../resources/img/salida.png" Width="30" Height="30" Stretch="Uniform"/>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                <TextBlock Text="{x:Static res:Resources.textEsperaContrincante}" 
                           Style="{StaticResource titulos}" FontSize="36" TextAlignment="Center" Margin="0,0,0,40"/>

                <Image Name="imgCarga" Source="../resources/img/cargando.png" Width="100" Height="100" Stretch="Uniform"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <RotateTransform x:Name="rotacionCarga_Img" Angle="0"/>
                    </Image.RenderTransform>
                    <Image.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="rotacionCarga_Img" 
                                                                   Storyboard.TargetProperty="Angle" 
                                                                   RepeatBehavior="Forever">
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.000" Value="0"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.125" Value="45"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.250" Value="90"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.375" Value="135"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.500" Value="180"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.625" Value="225"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.750" Value="270"/>
                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0.875" Value="315"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Image.Triggers>
                </Image>
            </StackPanel>
        </Grid>
    </Grid>
</Page>