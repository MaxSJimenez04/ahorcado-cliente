<Page x:Class="ClienteAhorcado.vistas.wLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wLogin">

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.25*"/>
            <ColumnDefinition Width="0.40*"/>
            <ColumnDefinition Width="0.25*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Left" 
                Margin="20" Name="btnRegresar" 
                Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
            <Path Data="{StaticResource IconoRegresar}"
                  Fill="#F4F3F2"
                  Width="30"
                  Height="30"
                  Stretch="Fill" />
        </Button>

        <Border Grid.Column="1" Margin="25,50" Background="#D9D9D9" CornerRadius="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.25*"/>
                    <RowDefinition Height="0.50*"/>
                    <RowDefinition Height="0.33*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{x:Static res:Resources.textInicioSesion}" HorizontalAlignment="Center"
                           VerticalAlignment="Center" Style="{StaticResource titulos}"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">

                    <TextBlock Text="{x:Static res:Resources.textNombreUsuario}" Style="{StaticResource texto}" Margin="0,0,0,5"/>

                    <Grid Margin="0,0,0,20" Width="360">
                        <TextBox Name="txtNombreUsuario" Height="60" HorizontalAlignment="Stretch" MaxLength="255"/>

                        <TextBlock Text="Ej: JugadorPro123" VerticalAlignment="Center" Margin="15,0,0,0" 
                                   Foreground="#A09D9D" FontSize="20" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource texto}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtNombreUsuario}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <TextBlock Text="{x:Static res:Resources.textContraseña}" Style="{StaticResource texto}" Margin="0,0,0,5"/>
                    <Grid Width="360">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <PasswordBox Name="pbContraseniaOculta" Grid.Column="0" Height="60" Width="Auto" HorizontalAlignment="Stretch"/>
                        <TextBox Name="txtContraseniaVisible" Grid.Column="0" Height="60" Width="Auto" Visibility="Collapsed" HorizontalAlignment="Stretch" MaxLength="255"/>

                        <Button Name="btnMostrarContrasenia" Grid.Column="1" Width="60" Height="60" Margin="-8,0,0,0"
                                Background="#807D7D" Cursor="Hand" Click="btnMostrarContrasenia_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">

                                    <Border x:Name="Borde" Background="{TemplateBinding Background}" CornerRadius="0,8,8,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Borde" Property="Background" Value="#A09D9D"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                            <TextBlock Text="👁" FontSize="20" Foreground="#F4F3F2"/>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button Name="btnIniciarSesion" Margin="0,10" Content="{x:Static res:Resources.btnIniciarSesion}" Click="btnIniciarSesion_Click"/>
                    <Button Name="btnCrearCuenta" Style="{StaticResource BotonSecundario}" Margin="0,10" Content="{x:Static res:Resources.btnCrearCuenta}" Click="btnCrearCuenta_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
