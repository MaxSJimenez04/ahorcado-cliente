<Page x:Class="ClienteAhorcado.vistas.wInicio"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wInicio">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.35*"/>
            <RowDefinition Height="0.65*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                 Text="AHORCADO"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 FontSize="100"
                 Margin="0,20,0,0"
                 Background="Transparent"
                 FontFamily="/resources/fonts/#Coming Soon"
        />

        

        <StackPanel Grid.Row="1" 
                    Orientation="Vertical" 
                    Margin="0,10,0,0"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

            <Button Name="btnJugar"
                    Margin="0,25"
                    Content="{x:Static res:Resources.btnJugar}" Click="btnJugar_Click"/>
            <Button Name="btnOpciones"
                    Margin="0,25"
                    Content="{x:Static res:Resources.btnOpciones}" Click="btnOpciones_Click"/>
            <Button Name="btnSalir"
                    Margin="0,25"
                    Content="{x:Static res:Resources.btnSalir}" Click="btnSalir_Click"/>
        </StackPanel>

    </Grid>
</Page>
