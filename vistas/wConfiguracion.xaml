<Page x:Class="ClienteAhorcado.vistas.wConfiguracion"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ClienteAhorcado.vistas"
      xmlns:res="clr-namespace:ClienteAhorcado.Properties"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1250"
      Title="wConfiguracion">

    <Grid Background="Transparent">

        <Grid Margin="50,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.20*"/>
                <RowDefinition Height="0.60*"/>
                <RowDefinition Height="0.20*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Left" 
                        Name="btnRegresar" 
                        Style="{StaticResource BotonRegresar}" Click="btnRegresar_Click">
                    <Path Data="{StaticResource IconoRegresar}" 
                          Fill="#F4F3F2" Width="30" Height="30" Stretch="Fill"/>
                </Button>

                <TextBlock Grid.Column="1" 
                           Text="{x:Static res:Resources.btnOpciones}" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Left" 
                           Margin="50,0,0,0"
                           Style="{StaticResource titulos}"/>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="20">

                <TextBlock Text="{x:Static res:Resources.textIdioma}" Style="{StaticResource texto}" Margin="0,0,0,5"/>

                <ComboBox Name="cbIdioma" SelectedIndex="0" Style="{StaticResource ComboBoxOpciones}" Width="500">
                    <ComboBoxItem Content="Español"/>
                    <ComboBoxItem Content="Inglés"/>
                </ComboBox>

            </StackPanel>

            <Grid Grid.Row="2">
            </Grid>

        </Grid>
    </Grid>
</Page>
