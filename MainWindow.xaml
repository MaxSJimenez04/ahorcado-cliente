<Window x:Class="ClienteAhorcado.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado" 
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.Background>
            <VisualBrush TileMode="Tile" Viewport="0,0,1,270" ViewportUnits="Absolute">
                <VisualBrush.Visual>
                    <Grid Width="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth}" Height="270">
                        <Image Source="resources/img/fondo_libreta.jpeg" Stretch="Fill" />
                    </Grid>
                </VisualBrush.Visual>
            </VisualBrush>
        </Grid.Background>

        <Frame Name="fmPantalla" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
